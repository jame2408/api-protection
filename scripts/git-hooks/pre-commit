#!/usr/bin/env bash
# pre-commit — runs the exact same gate as CI via scripts/ci-checks.sh
# (single source of truth), so a commit that passes locally will pass CI too.
#
# The docs/adr/ partial-staging guard below is preserved from the original
# adr-only hook: adr-lint (run inside ci-checks.sh) reads the working tree, so
# when ADR files are staged we refuse to run against a dirty docs/adr/ working
# copy that would not match what is being committed.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"

# Detect staged changes under docs/adr/ (any change type, including deletions)
if git diff --cached --name-only -- 'docs/adr/' | grep -q .; then
    # Refuse partial staging — adr-lint operates on working tree, not index
    if git diff --name-only -- 'docs/adr/' | grep -q .; then
        echo "[pre-commit] docs/adr/ has unstaged changes." >&2
        echo "             adr-lint reads working tree, so partial staging is unsafe." >&2
        echo "             Stage all docs/adr/ changes (or stash them) before committing:" >&2
        git diff --name-only -- 'docs/adr/' | sed 's/^/               /' >&2
        exit 1
    fi

    # Refuse untracked ADR files — they would be linted (working-tree glob) but
    # not committed, masking staged numbering gaps and producing false failures.
    untracked=$(git ls-files --others --exclude-standard -- 'docs/adr/adr-*.md')
    if [[ -n "$untracked" ]]; then
        echo "[pre-commit] docs/adr/ has untracked adr-*.md files." >&2
        echo "             They would be linted but not committed, masking numbering gaps." >&2
        echo "             Stage, remove, or .gitignore them before committing:" >&2
        printf '%s\n' "$untracked" | sed 's/^/               /' >&2
        exit 1
    fi
fi

# Fast checks only (format + adr-lint, no build/test, no Docker) for quick feedback
# on every commit. The full build+test gate runs at pre-push and in CI — both via
# `ci-checks.sh full`, the single source of truth.
# Bypass intentionally with `git commit --no-verify` (e.g. mid-WIP).
exec bash "$REPO_ROOT/scripts/ci-checks.sh" fast
