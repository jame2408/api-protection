#!/usr/bin/env bash
# pre-push — runs the full gate (scripts/ci-checks.sh full), identical to CI.
#
# This is the layer that makes "passes locally" mean "passes CI": both this hook
# and .github/workflows/ci.yml run `ci-checks.sh full`. Pushing a branch that
# would fail CI is caught here first.
#
# Needs Docker running (Testcontainers-based BDD tests). Bypass intentionally with
# `git push --no-verify`; CI still enforces on the server.
set -euo pipefail

REPO_ROOT="$(git rev-parse --show-toplevel)"
exec bash "$REPO_ROOT/scripts/ci-checks.sh" full
